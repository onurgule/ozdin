{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChatAskResponse",
  "type": "object",
  "required": ["answer", "found", "confidence", "citations"],
  "properties": {
    "answer": { "type": "string" },
    "found": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chunk_id", "book_title"],
        "properties": {
          "chunk_id": { "type": "string" },
          "book_title": { "type": "string" },
          "section_title": { "type": ["string", "null"] },
          "page_number": { "type": ["integer", "null"] },
          "surah_name": { "type": ["string", "null"] },
          "ayah_start": { "type": ["integer", "null"] },
          "ayah_end": { "type": ["integer", "null"] },
          "question_text": { "type": ["string", "null"] }
        }
      }
    },
    "disclaimer": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
