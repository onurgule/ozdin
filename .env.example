# API
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# Security
API_KEY=change-me-in-production
ADMIN_REINDEX_ENABLED=false
ADMIN_KEY=change-admin-key

# Database
DATABASE_URL=postgresql+asyncpg://yasar:yasar@localhost:5432/yasar_nuri

# Redis
REDIS_URL=redis://localhost:6379/0

# Index / cache
INDEX_VERSION=1
CACHE_TTL_REWRITE_SECONDS=86400
CACHE_TTL_RETRIEVAL_SECONDS=3600
CACHE_TTL_ANSWER_SECONDS=1800

# Gemini (backend only — never ship to client)
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=768

# Retrieval
RETRIEVAL_VECTOR_TOP_K=30
RETRIEVAL_FTS_TOP_K=30
RETRIEVAL_MERGED_TOP_N=20
RETRIEVAL_RERANK_TOP_K=8
RETRIEVAL_MIN_CONFIDENCE=0.35
RERANK_ENABLED=true

# Limits
MAX_QUESTION_LENGTH=2000
RATE_LIMIT_PER_MINUTE=60

# Feature flags
FEATURE_LOCAL_TTS_DEFAULT=true
FEATURE_SPEECH_INPUT_DEFAULT=true
FEATURE_DEBUG_EVIDENCE=false

# Logging
LOG_LEVEL=INFO
